# ANVX v2 env reference. Populated incrementally during the build.

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBKOOK_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Stripe (subscription scaffold + pack Checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_METERED_PRICE_ID=
STRIPE_CLOSE_PACK_PRICE_ID=
STRIPE_AI_AUDIT_PACK_PRICE_ID=

# Routing monetization (scaffolded, not enforced during design-partner phase)
ROUTING_MARKUP_BPS=0
BILLING_ENFORCEMENT_ENABLED=false		 # when true, Stripe subscription status gates Pro features

# Encryption
ANVX_MASTER_ENCRYPTION_KEY=

# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Routing engine
ROUTING_BASE_URL=https://anvx.io/v1
ROUTING_FAIL_MODE_DEFAULT=open			 # open: pass through; closed: block on internal error

#Notifications
RESEND_API_KEY=					 # email provider for notification routing
