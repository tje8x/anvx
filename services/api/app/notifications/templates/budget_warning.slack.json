{
  "blocks": [
    { "type": "header", "text": { "type": "plain_text", "text": "⚠ Budget at {{ pct | default(80) }}% — {{ scope | default('daily limit') }}" } },
    { "type": "section", "text": { "type": "mrkdwn", "text": "*Spend:* ${{ '%.2f' | format(spend_cents / 100) }} of ${{ '%.2f' | format(limit_cents / 100) }}" } },
    { "type": "actions", "elements": [
      { "type": "button", "text": { "type": "plain_text", "text": "Review" }, "url": "{{ webapp_base_url }}/routing" }
    ]}
  ]
}
